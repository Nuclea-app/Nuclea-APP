generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  runtime       = "vercel-edge"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@unique([provider, providerAccountId])
  @@map("accounts")
}
 
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@map("sessions")
}
 
model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String?              @unique
  emailVerified       DateTime?            @map("email_verified")
  image               String?
  password            String?
  birthdate           DateTime?
  accounts            Account[]
  sessions            Session[]
  passwordResetToken  PasswordResetToken[]
  capsules            Capsule[]

  @@map("users")
}

model Capsule {
  id             String            @id @default(cuid())
  type           CapsuleType
  name           String
  description    String?
  coverUrl       String?
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  memories       Memory[]
  deliveries     CapsuleDelivery[]
  futureMessages FutureMessage[]
  createdAt      DateTime          @default(now())

  @@map("capsules")
}

model Memory {
  id        String     @id @default(cuid())
  type      MemoryType
  content   String?    @db.Text
  fileUrl   String?
  date      DateTime   @default(now())
  isFavorite Boolean   @default(false)
  capsuleId String
  capsule   Capsule    @relation(fields: [capsuleId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@map("memories")
}

enum CapsuleType {
  LEGACY
  TOGETHER
  PET
  ORIGIN
}

enum MemoryType {
  PHOTO
  VIDEO
  AUDIO
  NOTE
  DRAWING
}

model CapsuleDelivery {
  id             String    @id @default(cuid())
  capsuleId      String
  capsule        Capsule   @relation(fields: [capsuleId], references: [id], onDelete: Cascade)
  token          String    @unique @default(cuid())
  recipientName  String
  relation       String
  relationCustom String?
  email          String?
  phone          String?
  deliveredAt    DateTime?
  createdAt      DateTime  @default(now())

  @@map("capsule_deliveries")
}

model FutureMessage {
  id         String     @id @default(cuid())
  capsuleId  String
  capsule    Capsule    @relation(fields: [capsuleId], references: [id], onDelete: Cascade)
  type       MemoryType
  content    String?    @db.Text
  fileUrl    String?
  unlocksAt  DateTime
  isUnlocked Boolean    @default(false)
  createdAt  DateTime   @default(now())

  @@map("future_messages")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}